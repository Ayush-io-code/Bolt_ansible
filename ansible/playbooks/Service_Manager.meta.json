{
  "description": "Start, stop, restart, enable, or disable any systemd service",
  "inputs": [
    {
      "name": "service_name",
      "label": "Service Name",
      "type": "text",
      "placeholder": "nginx",
      "default": "nginx"
    },
    {
      "name": "action",
      "label": "Action",
