{
  "description": "Provision or terminate an AWS EC2 instance with configurable instance type, AMI, and region",
  "inputs": [
    {
      "name": "aws_region",
      "label": "AWS Region",
      "type": "select",
      "options": [
        "us-east-1", "us-east-2", "us-west-1", "us-west-2",
        "eu-west-1", "eu-west-2", "eu-central-1",
        "ap-south-1", "ap-southeast-1", "ap-southeast-2", "ap-northeast-1"
      ],
      "default": "us-east-1"
    },
    {
      "name": "instance_type",
      "label": "Instance Type",
      "type": "select",
      "options": [
        "t2.micro", "t2.small", "t2.medium",
        "t3.micro", "t3.small", "t3.medium", "t3.large",
        "m5.large", "m5.xlarge",
        "c5.large", "c5.xlarge"
      ],
      "default": "t3.micro"
    },
    {
      "name": "ami_id",
      "label": "AMI ID",
      "type": "text",
      "placeholder": "ami-0abcdef1234567890",
      "default": "ami-0c55b159cbfafe1f0"
    },
    {
      "name": "key_name",
      "label": "Key Pair Name",
      "type": "text",
      "placeholder": "my-keypair",
      "default": ""
    },
    {
      "name": "instance_name",
      "label": "Instance Name (Tag)",
      "type": "text",
      "placeholder": "my-server",
      "default": "bolt-instance"
    },
    {
      "name": "security_group",
      "label": "Security Group ID",
      "type": "text",
      "placeholder": "sg-0abc123 (leave blank for default)",
      "default": ""
    },
    {
      "name": "ec2_action",
      "label": "Action",
      "type": "select",
      "options": ["provision", "terminate", "start", "stop"],
      "default": "provision"
    },
    {
      "name": "volume_size",
      "label": "Root Volume Size (GB)",
      "type": "select",
      "options": ["8", "16", "20", "30", "50", "100"],
      "default": "20"
    }
  ]
}
